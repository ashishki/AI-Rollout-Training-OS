APP_ENV=production
APP_PORT=8000
IMAGE_TAG=local

DATABASE_URL=postgresql+psycopg://ai_rollout:replace-with-postgres-password@postgres:5432/ai_rollout_training_os
POSTGRES_USER=ai_rollout
POSTGRES_PASSWORD=replace-with-postgres-password
POSTGRES_DB=ai_rollout_training_os
POSTGRES_PORT=5432

SECRET_KEY=replace-with-random-32-byte-secret
AI_PROVIDER_API_KEY=replace-with-provider-api-key
MODEL_FAST=replace-with-fast-model
MODEL_STRONG=replace-with-strong-model
EMBEDDING_MODEL=replace-with-embedding-model

INDEX_MAX_AGE_DAYS=7
FEEDBACK_TIMEOUT_SECONDS=60
REMINDER_WINDOW_DAYS=3
REMINDER_DELIVERY_ENABLED=false
REMINDER_DELIVERY_CHANNEL=
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
RETENTION_DAYS=365
SSO_ENABLED=false
OIDC_ISSUER_URL=https://idp.example.com
OIDC_CLIENT_ID=replace-with-oidc-client-id
OIDC_CLIENT_SECRET=replace-with-oidc-client-secret
OIDC_REDIRECT_URI=https://app.example.com/auth/oidc/callback
